# Required — Gmail SMTP credentials for the contact form
SMTP_USER=
SMTP_PASS=
# Optional — override default From address
SMTP_FROM=

# Optional — WebSocket server URL for realtime features (live cursors, chat, presence)
# Leave empty to disable realtime features entirely
NEXT_PUBLIC_WS_URL=

# Optional — Umami analytics
UMAMI_DOMAIN=
UMAMI_SITE_ID=
